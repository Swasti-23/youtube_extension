# LLM provider configuration (server-side only — never expose to the extension)
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# CORS: set to your extension origin, e.g. chrome-extension://YOUR_EXTENSION_ID
ALLOWED_ORIGIN=

# Required for /api/extract and /api/sync — extension sends: Authorization: Bearer <token>
API_AUTH_TOKEN=

# Phase 4 — L2 cache database (not used until Phase 4)
DATABASE_URL=
